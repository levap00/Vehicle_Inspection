PORT=3000
# Klucz JWT – zmień na długi losowy ciąg!
JWT_SECRET=zmien_mnie_na_dlugi_losowy_ciag_znakow_abc123

# Hasło domyślnego konta admin (przy pierwszym uruchomieniu)
ADMIN_PASS=Admin1234!

# Klucz do tworzenia kont kierowców przez curl/Postman (bez JWT)
ADMIN_KEY=ADMIN_SECRET_CHANGE_ME

# Stary klucz API (backward compat z aplikacją zanim nie zaloguje JWT)
API_KEY=TEST123

# Ścieżka do bazy SQLite
DB_PATH=./vi.db
