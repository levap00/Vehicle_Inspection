<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:padding="@dimen/screen_padding">

    <LinearLayout
        android:id="@+id/loginCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_panel"
        android:elevation="2dp"
        android:orientation="vertical"
        android:padding="@dimen/panel_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="560dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/app_name"
            android:scaleType="centerInside"
            android:src="@drawable/logo_transkap" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_horizontal"
            android:text="Panel Kierowcy"
            android:textColor="@color/ink"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:text="Zaloguj sie do aplikacji kierowcy"
            android:textColor="@color/muted"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvLabelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Login"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDriverName"
            android:layout_width="match_parent"
            android:layout_height="@dimen/control_height"
            android:layout_marginTop="6dp"
            android:background="@drawable/edit_text_background"
            android:hint="Wprowadz login"
            android:inputType="textNoSuggestions"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Haslo"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="@dimen/control_height"
            android:layout_marginTop="6dp"
            android:background="@drawable/edit_text_background"
            android:hint="Wprowadz haslo"
            android:inputType="textPassword"
            android:textColor="@color/ink"
            android:textColorHint="@color/muted"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/accent"
            android:text="Zaloguj sie"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:cornerRadius="6dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
