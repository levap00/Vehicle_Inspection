<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarMain"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_toolbar"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Przed wyjazdem"
        app:titleCentered="false"
        app:titleTextColor="@color/white" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabModule"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarMain" />

    <ScrollView
        android:id="@+id/scrollMain"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:padding="@dimen/screen_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarMain">

        <LinearLayout
            android:id="@+id/contentMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/sectionVehicle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/tvVehicleTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pojazd i lista kontrolna"
                    android:textColor="@color/ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Wybierz auto, sprawdz wyposazenie i jednym przyciskiem zaznacz komplet."
                    android:textColor="@color/muted"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Pojazd"
                            android:textColor="@color/muted"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/control_height"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/edit_text_background"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Naczepa"
                            android:textColor="@color/muted"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spTrailer"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/control_height"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/edit_text_background"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvChecklistTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lista kontrolna przed wyjazdem"
                        android:textColor="@color/ink"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChecklistSelectAll"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/control_height"
                        android:backgroundTint="@color/primary"
                        android:minWidth="150dp"
                        android:text="Zaznacz wszystko"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="6dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChecklistClear"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height"
                    android:layout_marginTop="10dp"
                    android:text="Odznacz liste"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    app:cornerRadius="6dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:id="@+id/checklistContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionInspection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/panel_gap"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:padding="@dimen/panel_padding">

                <TextView
                    android:id="@+id/tvInspectionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Inspekcja pojazdu"
                    android:textColor="@color/ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Wyposazenie i stan"
                    android:textColor="@color/ink"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <CheckBox
                    android:id="@+id/cbRegistrationDoc"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_check_item"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Dowod rejestracyjny"
                    android:textColor="@color/ink"
                    android:textSize="16sp" />

                <CheckBox
                    android:id="@+id/cbTablet"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_check_item"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Tablet"
                    android:textColor="@color/ink"
                    android:textSize="16sp" />

                <CheckBox
                    android:id="@+id/cbNoDamage"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/control_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_check_item"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Brak widocznych uszkodzen"
                    android:textColor="@color/ink"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Zdjecia pojazdu"
                    android:textColor="@color/ink"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2"
                    android:useDefaultMargins="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPhotoLeft"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height"
                        android:layout_columnWeight="1"
                        android:backgroundTint="@color/info"
                        android:text="Lewy bok"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPhotoFront"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height"
                        android:layout_columnWeight="1"
                        android:backgroundTint="@color/info"
                        android:text="Przod"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPhotoRight"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height"
                        android:layout_columnWeight="1"
                        android:backgroundTint="@color/info"
                        android:text="Prawy bok"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPhotoBack"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height"
                        android:layout_columnWeight="1"
                        android:backgroundTint="@color/info"
                        android:text="Tyl"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPhotoInside"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/control_height"
                        android:layout_columnSpan="2"
                        android:layout_columnWeight="1"
                        android:backgroundTint="@color/info"
                        android:text="Wnetrze"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:cornerRadius="6dp" />
                </GridLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:columnCount="2"
                    android:useDefaultMargins="true">

                    <ImageView
                        android:id="@+id/ivPhotoLeft"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/photo_height"
                        android:layout_columnWeight="1"
                        android:background="@drawable/image_placeholder_background"
                        android:scaleType="centerCrop"
                        tools:src="@mipmap/ic_launcher" />

                    <ImageView
                        android:id="@+id/ivPhotoFront"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/photo_height"
                        android:layout_columnWeight="1"
                        android:background="@drawable/image_placeholder_background"
                        android:scaleType="centerCrop"
                        tools:src="@mipmap/ic_launcher" />

                    <ImageView
                        android:id="@+id/ivPhotoRight"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/photo_height"
                        android:layout_columnWeight="1"
                        android:background="@drawable/image_placeholder_background"
                        android:scaleType="centerCrop"
                        tools:src="@mipmap/ic_launcher" />

                    <ImageView
                        android:id="@+id/ivPhotoBack"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/photo_height"
                        android:layout_columnWeight="1"
                        android:background="@drawable/image_placeholder_background"
                        android:scaleType="centerCrop"
                        tools:src="@mipmap/ic_launcher" />

                    <ImageView
                        android:id="@+id/ivPhotoInside"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/photo_height"
                        android:layout_columnSpan="2"
                        android:layout_columnWeight="1"
                        android:background="@drawable/image_placeholder_background"
                        android:scaleType="centerCrop"
                        tools:src="@mipmap/ic_launcher" />
                </GridLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="@color/accent"
                    android:text="Zapisz inspekcje"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    app:cornerRadius="6dp" />
            </LinearLayout>

            <Space
                android:id="@+id/sectionRoadCard"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
